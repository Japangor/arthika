{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/stocks/:symbol", "destination": "/api/index.js" },
    { "source": "/stocks", "destination": "/api/index.js" },
    { "source": "/screener", "destination": "/api/index.js" },
    { "source": "/gainers", "destination": "/api/index.js" },
    { "source": "/losers", "destination": "/api/index.js" },
    { "source": "/sitemap.xml", "destination": "/api/index.js" },
    { "source": "/robots.txt", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  }
}
